{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "description": "Persistent memory across sessions",
      "disabled": true
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "description": "Chain-of-thought reasoning",
      "autoApprove": [
        "sequentialthinking"
      ]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com",
      "description": "Vercel deployments and projects",
      "disabled": true
    },
    "railway": {
      "command": "npx",
      "args": [
        "-y",
        "@railway/mcp-server"
      ],
      "description": "Railway deployments"
    },
    "cloudflare-docs": {
      "type": "http",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "description": "Cloudflare documentation search"
    },
    "magic": {
      "command": "npx",
      "args": [
        "-y",
        "@magicuidesign/mcp@latest"
      ],
      "description": "Magic UI components"
    },
    "insaits": {
      "command": "python3",
      "args": [
        "-m",
        "insa_its.mcp_server"
      ],
      "description": "AI-to-AI security monitoring — anomaly detection, credential exposure, hallucination checks. Install: pip install insa-its",
      "disabled": true
    },
    "token-optimizer": {
      "command": "npx",
      "args": [
        "-y",
        "token-optimizer-mcp"
      ],
      "description": "Token optimization for 95%+ context reduction",
      "autoApprove": [
        "smart_status"
      ]
    }
  },
  "_disabled": {
    "_comment": "API 키 설정이 필요한 서버들. 사용하려면 mcpServers로 이동하고 YOUR_*_HERE를 실제 키로 교체하세요.",
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_KEY_HERE"
      },
      "description": "Web scraping and crawling"
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=YOUR_PROJECT_REF"
      ],
      "description": "Supabase database operations"
    },
    "exa-web-search": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "YOUR_EXA_API_KEY_HERE"
      },
      "description": "Web search, research, and data ingestion via Exa API"
    },
    "fal-ai": {
      "command": "npx",
      "args": [
        "-y",
        "fal-ai-mcp-server"
      ],
      "env": {
        "FAL_KEY": "YOUR_FAL_KEY_HERE"
      },
      "description": "AI image/video/audio generation via fal.ai models"
    },
    "browserbase": {
      "command": "npx",
      "args": [
        "-y",
        "@browserbasehq/mcp-server-browserbase"
      ],
      "env": {
        "BROWSERBASE_API_KEY": "YOUR_BROWSERBASE_KEY_HERE"
      },
      "description": "Cloud browser sessions via Browserbase"
    },
    "browser-use": {
      "type": "http",
      "url": "https://api.browser-use.com/mcp",
      "headers": {
        "x-browser-use-api-key": "YOUR_BROWSER_USE_KEY_HERE"
      },
      "description": "AI browser agent for web tasks"
    },
    "confluence": {
      "command": "npx",
      "args": [
        "-y",
        "confluence-mcp-server"
      ],
      "env": {
        "CONFLUENCE_BASE_URL": "YOUR_CONFLUENCE_URL_HERE",
        "CONFLUENCE_EMAIL": "YOUR_EMAIL_HERE",
        "CONFLUENCE_API_TOKEN": "YOUR_CONFLUENCE_TOKEN_HERE"
      },
      "description": "Confluence Cloud integration"
    },
    "clickhouse": {
      "type": "http",
      "url": "https://mcp.clickhouse.cloud/mcp",
      "description": "ClickHouse analytics queries"
    },
    "cloudflare-workers-builds": {
      "type": "http",
      "url": "https://builds.mcp.cloudflare.com/mcp",
      "description": "Cloudflare Workers builds"
    },
    "cloudflare-workers-bindings": {
      "type": "http",
      "url": "https://bindings.mcp.cloudflare.com/mcp",
      "description": "Cloudflare Workers bindings"
    },
    "cloudflare-observability": {
      "type": "http",
      "url": "https://observability.mcp.cloudflare.com/mcp",
      "description": "Cloudflare observability/logs"
    }
  },
  "_comments": {
    "usage": "필요한 서버를 .kiro/settings/mcp.json에 복사하여 사용",
    "env_vars": "_disabled 섹션의 YOUR_*_HERE 플레이스홀더를 실제 값으로 교체 후 mcpServers로 이동",
    "excluded": "context7, github, playwright는 Kiro 내장 기능이므로 제외",
    "context_warning": "컨텍스트 윈도우 보존을 위해 10개 이하로 활성화 권장"
  }
}