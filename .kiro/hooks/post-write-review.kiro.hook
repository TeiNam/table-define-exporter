{
  "name": "Post-Write Code Review",
  "version": "1.0.0",
  "description": "Post-Write Code Review",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Briefly check the file just written for: 1) any console.log statements (flag for removal — ignore console.error/console.warn), 2) new TODO/FIXME/HACK comments (suggest creating tracked issues instead). Only report if issues are found."
  }
}
