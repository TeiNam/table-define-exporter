{
  "name": "Diagnostics After Code Edit",
  "version": "1.0.0",
  "description": "Diagnostics After Code Edit",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.rs"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A Rust file was edited. Use getDiagnostics to check for compile errors, borrow checker errors, clippy warnings, and type errors. Report any issues found concisely. Do NOT use executeBash or terminal."
  }
}
